# Required for real VPS-backed usage
TON_SSH_HOST=your-vps-hostname-or-ip
TON_SSH_PORT=22
TON_SSH_USER=root

# SSH auth mode
# agent is the default and uses your local SSH agent via SSH_AUTH_SOCK
TON_SSH_AUTH_MODE=agent

# Required when TON_SSH_AUTH_MODE=agent
SSH_AUTH_SOCK=/tmp/ssh-agent.sock

# Required when TON_SSH_AUTH_MODE=inline_key
# TON_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Required when TON_SSH_AUTH_MODE=key_path
# TON_SSH_PRIVATE_KEY_PATH=/absolute/path/to/your/private_key

# Optional only for key_path or inline_key auth modes
TON_SSH_PASSPHRASE=

# Host verification is mandatory in production
# Provide either a host fingerprint, a known_hosts file path, or both
TON_SSH_HOST_FINGERPRINT=SHA256:your-server-host-key-fingerprint
# TON_SSH_KNOWN_HOSTS_PATH=/absolute/path/to/known_hosts

# Optional SSH tuning
TON_SSH_READY_TIMEOUT_MS=20000

# TonAPI provider lookup
TONAPI_BASE_URL=https://tonapi.io
# TONAPI_API_KEY=your-tonapi-key

# Remote TON Storage paths
TON_REMOTE_BASE_DIR=/var/lib/ton-storage
TON_REMOTE_BAG_SOURCE_DIR=/var/lib/bag-sources

# Comma-separated allowlist for guarded remote deletion
# Defaults to TON_REMOTE_BASE_DIR if omitted
TON_REMOTE_DELETE_ALLOWED_DIRS=/var/lib/ton-storage,/var/lib/ton-storage/uploads

# Local app-server staging subdirectory inside .ton-storage/
TON_LOCAL_STAGING_DIR=staging

# Optional live integration test target for get-meta
TON_LIVE_META_OUTPUT_PATH=/var/lib/ton-storage/test-output/example.meta
